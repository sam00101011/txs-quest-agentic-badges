{
  "name": "agentic-poap-badge-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:farcaster": "node scripts/generate-farcaster-manifest.mjs",
    "prepare:badges": "node scripts/generate-badge-markdown-catalog.mjs",
    "assets:sample": "node scripts/generate-sample-assets.mjs",
    "deploy:local": "node scripts/generate-badge-markdown-catalog.mjs && bun scripts/deploy-local.mjs",
    "deploy:testnet": "node scripts/generate-badge-markdown-catalog.mjs && bun scripts/deploy-network.mjs --config config/testnet.json",
    "seed:catalog": "node scripts/generate-badge-markdown-catalog.mjs && bun scripts/seed-network-catalog.mjs",
    "set:public-url": "node scripts/generate-badge-markdown-catalog.mjs && bun scripts/set-public-base-url.mjs",
    "define:x402-badge": "bun scripts/define-x402-badge.mjs",
    "define:payment-badge": "bun scripts/define-x402-badge.mjs --adapter PAYMENT_HISTORY",
    "issue:agent-proof": "node scripts/issue-agent-proof.mjs",
    "issue:event-proof": "node scripts/issue-event-proof.mjs",
    "update:badge-policy": "bun scripts/update-badge-proof-policy.mjs",
    "mint:server": "bun scripts/mpp-mint-server.mjs",
    "payment-backend:server": "bun scripts/payment-history-backend.mjs",
    "internal-service:server": "bun scripts/internal-service-backend.mjs",
    "x402:server": "bun scripts/x402-proof-server.mjs",
    "oracle:server": "bun scripts/oracle-proof-server.mjs",
    "farcaster:server": "bun scripts/farcaster-proof-server.mjs",
    "farcaster:set-domain": "node scripts/set-farcaster-domain-association.mjs",
    "verify:browser:gallery": "node scripts/verify-browser-gallery.mjs",
    "verify:browser:event-proof": "node scripts/verify-browser-event-proof.mjs",
    "verify:browser:issue": "node scripts/verify-browser-issuance.mjs",
    "verify:browser:mpp-mint": "node scripts/verify-browser-mpp-mint.mjs",
    "verify:browser:profile": "node scripts/verify-browser-profile.mjs",
    "verify:browser:results": "node scripts/verify-browser-results.mjs",
    "verify:browser:share": "node scripts/verify-browser-share-page.mjs",
    "verify:browser:unlocks": "node scripts/verify-browser-unlock-adapters.mjs",
    "verify:browser:wallet-connect": "node scripts/verify-browser-wallet-connect.mjs",
    "verify:browser:wagmi": "node scripts/verify-browser-wagmi.mjs",
    "verify:browser:wallet-extension": "node scripts/verify-browser-wallet-extension.mjs",
    "verify:event-proof:expiry": "bun scripts/verify-event-proof-expiry.mjs",
    "verify:payment:flow": "bun scripts/verify-payment-history-flow.mjs",
    "verify:x402:flow": "bun scripts/verify-x402-history-flow.mjs",
    "verify:mpp:tempo": "node scripts/verify-mpp-tempo.mjs",
    "cf:pages:create": "bunx wrangler pages project create txs-quest --production-branch main",
    "cf:pages:deploy": "bunx wrangler pages deploy dist --project-name txs-quest --branch main",
    "dev": "node scripts/generate-farcaster-manifest.mjs && node scripts/generate-badge-markdown-catalog.mjs && vite",
    "build": "node scripts/generate-farcaster-manifest.mjs && node scripts/generate-badge-markdown-catalog.mjs && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@farcaster/frame-sdk": "^0.1.14",
    "@farcaster/quick-auth": "^0.0.8",
    "@wagmi/core": "^3.4.0",
    "@x402/axios": "^2.7.0",
    "@x402/evm": "^2.7.0",
    "axios": "^1.13.6",
    "mppx": "^0.4.7",
    "viem": "^2.47.5",
    "wagmi": "^3.5.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "vite": "^6.0.7"
  }
}
